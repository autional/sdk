{
  "name": "@authms/plugin-tenant",
  "version": "0.2.1",
  "description": "AuthMS Tenant Plugin — Multi-tenant switching components for @authms/core",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external @authms/core",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external @authms/core",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "auth",
    "authentication",
    "tenant",
    "multi-tenant",
    "authms",
    "plugin"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@authms/core": ">=0.1.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@authms/tsconfig": ">=0.1.0",
    "@types/react": "^19.0.0",
    "react": ">=18.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
