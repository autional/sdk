{
  "name": "@authms/plugin-mfa",
  "version": "0.1.1",
  "description": "AuthMS MFA Plugin — Multi-Factor Authentication UI components and flows for @authms/react",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external react --external react-dom --external @authms/core --external @authms/react",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external react --external react-dom --external @authms/core --external @authms/react",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "auth",
    "authentication",
    "mfa",
    "totp",
    "2fa",
    "authms",
    "plugin"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@authms/core": ">=0.1.0",
    "@authms/react": ">=0.1.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@authms/core": ">=0.1.0",
    "@authms/react": ">=0.1.0"
  },
  "devDependencies": {
    "@authms/tsconfig": ">=0.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": ">=18.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
