{
  "name": "@authms/miniapp",
  "version": "0.1.1",
  "description": "AuthMS WeChat Mini Program SDK — platform adapter, WeChat login, and token management",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean --external @authms/core",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch --external @authms/core",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "auth",
    "wechat",
    "miniprogram",
    "miniapp",
    "authms"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@authms/core": ">=0.1.0"
  },
  "dependencies": {
    "@authms/core": ">=0.1.0"
  },
  "devDependencies": {
    "@authms/tsconfig": ">=0.1.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
