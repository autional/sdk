{
  "name": "create-authms-app",
  "version": "0.1.0",
  "description": "Scaffold a new AuthMS project with React, Vue, or Next.js",
  "bin": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --external inquirer",
    "dev": "tsup src/index.ts --format esm --watch --external inquirer",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "files": ["dist"],
  "keywords": ["authms", "scaffold", "cli", "create-app"],
  "license": "MIT",
  "dependencies": {
    "inquirer": "^12.0.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
